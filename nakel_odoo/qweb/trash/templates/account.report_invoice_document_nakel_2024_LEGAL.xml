<!-- Wrapper para usar el layout legal de Argentina existente en Odoo -->
<!-- Genera el reporte usando l10n_ar.report_invoice_document -->
<t t-name="account.report_invoice_document_nakel_2024_LEGAL">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="o">
            <t t-set="lang" t-value="o.partner_id.lang"/>
            <!-- l10n_ar.report_invoice_document espera la variable 'o' -->
            <t t-call="l10n_ar.report_invoice_document" t-lang="lang"/>
        </t>
    </t>
</t>

