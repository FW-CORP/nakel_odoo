<!-- Template mejorado: Nota de Crédito Nakel 2024 -->
<!-- Cumple con RG AFIP 4294/2024 incluyendo QR Code obligatorio -->
<t t-name="account.report_credit_note_document_nakel_2024">
<t t-call="web.html_container">
<t t-foreach="docs" t-as="o">
<!-- Variables fiscales -->
<t t-set="report_date" t-value="o.invoice_date"/>
<t t-set="report_number" t-value="o.name"/>
<t t-call="web.external_layout">
    <div class="page">
      
      <!-- Espacio en blanco reservado para encabezado por defecto de Odoo -->
      <div style="height:30px;"/>

      <!-- Encabezado fiscal -->
      <div class="fiscal-header" style="border-bottom: 2px solid #000; margin-bottom: 15px; padding-bottom: 10px;">
        <div class="row">
          <div class="col-4">
            <br/>
            <strong t-field="o.company_id.name"/>
          </div>
          <div class="col-4 text-center">
            <h2 style="font-size: 32px; font-weight: bold; margin: 0; color: #d32f2f;">NOTA DE CRÉDITO</h2>
            <p style="margin: 5px 0; font-size: 16px; font-weight: bold;">
              <t t-if="o.move_type == 'out_refund' and o.l10n_latam_document_type_id.code == '11'">Tipo: NC-B (Consumidor Final)</t>
              <t t-if="o.move_type == 'out_refund' and o.l10n_latam_document_type_id.code == '8'">Tipo: NC-A (Responsable Inscripto)</t>
              <t t-if="o.move_type == 'out_refund' and o.l10n_latam_document_type_id.code == '3'">Tipo: NC-C (Exento)</t>
              <t t-if="not (o.move_type == 'out_refund' and o.l10n_latam_document_type_id and o.l10n_latam_document_type_id.code)">Nota de Crédito</t>
            </p>
          </div>
          <div class="col-4 text-right">
            <small>
              Nro: <span t-field="o.name"/><br/>
              Fecha: <span t-field="o.invoice_date" t-options="{'widget': 'date'}"/><br/>
              CUIT: <span t-field="o.company_id.vat"/>
            </small>
          </div>
        </div>
        <div class="row mt-2" style="font-size: 12px;">
          <div class="col-6">
            <span t-field="o.company_id.street"/> - <span t-field="o.company_id.city"/><br/>
            <span t-field="o.company_id.state_id.name"/> - <span t-field="o.company_id.zip"/><br/>
            <t t-if="o.company_id.website"><span t-field="o.company_id.website"/></t>
          </div>
          <div class="col-6 text-right">
            IVA Responsable Inscripto<br/>
            <!-- Campos opcionales de AFIP - Mostrar solo si existen -->
            <!-- IIBB e Inicio de actividades se mostrarán cuando estén disponibles -->
          </div>
        </div>
      </div>

      <!-- Referencia a factura original -->
      <div class="row mb-2" style="background-color: #fff3cd; padding: 10px; border: 1px solid #ffc107;">
        <div class="col-12">
          <strong>⚠️ NOTA DE CRÉDITO</strong><br/>
          <t t-if="o.reversed_entry_id">
            Referencia a factura: <span t-field="o.reversed_entry_id.name"/>
          </t>
          <t t-else="">
            Esta nota de crédito corrige/devolve la operación facturada anteriormente
          </t>
        </div>
      </div>

      <!-- Datos del cliente -->
      <h5 class="mt-2 mb-1"><strong>DATOS DEL CLIENTE</strong></h5>
      <div class="row mb-2">
        <div class="col-6">
          <t t-if="o.partner_id.name">Nombre: <span t-field="o.partner_id.name"/></t><br/>
          <t t-if="o.partner_id.vat">CUIT/DNI: <span t-field="o.partner_id.vat"/></t><br/>
          <t t-if="o.partner_id.phone">Teléfono: <span t-field="o.partner_id.phone"/></t><br/>
          <t t-if="o.partner_id.email">e-mail: <span t-field="o.partner_id.email"/></t><br/>
        </div>
        <div class="col-6 text-right">
          <t t-if="o.partner_id.street">Domicilio: <span t-field="o.partner_id.street"/></t>
          <t t-if="o.partner_id.street2"> - <span t-field="o.partner_id.street2"/></t><br/>
          <t t-if="o.partner_id.city">Localidad: <span t-field="o.partner_id.city"/></t><br/>
          <t t-if="o.partner_id.state_id">Provincia: <span t-field="o.partner_id.state_id.name"/></t><br/>
          <t t-if="o.partner_id.zip">C.P.: <span t-field="o.partner_id.zip"/></t>
        </div>
      </div>

      <!-- Motivo de la nota de crédito -->
      <t t-if="o.ref">
        <h5 class="mt-2 mb-1"><strong>MOTIVO</strong></h5>
        <div class="row mb-2">
          <div class="col-12">
            <span t-field="o.ref"/>
          </div>
        </div>
      </t>

      <!-- Detalle de productos/servicios -->
      <h5 class="mt-2 mb-1"><strong>DETALLE DE PRODUCTOS/SERVICIOS</strong></h5>
      <div class="row mt-3 mb-2">
        <div class="col-12">
          <table class="table table-sm" style="border-collapse: collapse; width: 100%; margin-bottom: 20px;">
            <thead>
              <tr>
                <th style="border: 1px solid #000; padding: 8px; background-color: #f8f9fa;">Código</th>
                <th style="border: 1px solid #000; padding: 8px; background-color: #f8f9fa;">Descripción</th>
                <th style="border: 1px solid #000; padding: 8px; background-color: #f8f9fa; text-align: center;">Cantidad</th>
                <th style="border: 1px solid #000; padding: 8px; background-color: #f8f9fa; text-align: right;">Precio Unit.</th>
                <th style="border: 1px solid #000; padding: 8px; background-color: #f8f9fa; text-align: right;">Impuestos</th>
                <th style="border: 1px solid #000; padding: 8px; background-color: #f8f9fa; text-align: right;">Subtotal</th>
              </tr>
            </thead>
            <tbody>
              <t t-foreach="o.invoice_line_ids" t-as="l">
                <!-- Línea de producto -->
                <tr t-if="not l.display_type or l.display_type == 'product'">
                  <td style="border: 1px solid #000; padding: 8px; vertical-align: top;"><span t-field="l.product_id.default_code"/></td>
                  <td style="border: 1px solid #000; padding: 8px; vertical-align: top;"><span t-field="l.product_id.name"/></td>
                  <td style="border: 1px solid #000; padding: 8px; vertical-align: top; text-align: center;"><span t-esc="'%.2f' % (l.quantity or 0)"/></td>
                  <td style="border: 1px solid #000; padding: 8px; vertical-align: top; text-align: right;"><span t-esc="'%.2f' % (l.price_unit or 0)"/></td>
                  <td style="border: 1px solid #000; padding: 8px; vertical-align: top; text-align: right;">
                    <t t-if="l.tax_ids">
                      <t t-set="tax_display" t-value="', '.join([(tax.invoice_label or tax.name or '') for tax in l.tax_ids])"/>
                      <span t-esc="tax_display"/>
                    </t>
                    <t t-else="">0%</t>
                  </td>
                  <td style="border: 1px solid #000; padding: 8px; vertical-align: top; text-align: right;"><span t-esc="'%.2f' % (l.price_subtotal or 0)"/></td>
                </tr>
                <!-- Sección -->
                <tr t-elif="l.display_type == 'line_section'">
                  <td colspan="6" style="border: 1px solid #000; padding: 8px; font-weight: 700; background-color: #f8f9fa;">
                    <span t-field="l.name" t-options="{'widget': 'text'}"/>
                  </td>
                </tr>
                <!-- Nota -->
                <tr t-elif="l.display_type == 'line_note'">
                  <td colspan="6" style="border: 1px solid #000; padding: 8px; font-style: italic; background-color: #fafafa;">
                    <span t-field="l.name" t-options="{'widget': 'text'}"/>
                  </td>
                </tr>
              </t>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Totales y QR Code -->
      <div class="row mt-3">
        <div class="col-6">
          <!-- QR Code (OBLIGATORIO desde 2024 - RG AFIP 4294/2024) -->
          <div style="text-align: center; border: 1px solid #ccc; padding: 10px;">
            <!-- QR Code placeholder - Se mostrará cuando esté disponible en facturación electrónica -->
            <div style="width: 120px; height: 120px; border: 1px dashed #ccc; margin: 0 auto; display: flex; align-items: center; justify-content: center;">
              <small>QR Code<br/>(disponible en facturación electrónica)</small>
            </div>
            <br/>
            <small>QR Code según RG AFIP 4294/2024</small>
          </div>
        </div>
        <div class="col-6">
          <table style="width: 100%; margin-left: auto;">
            <tr>
              <td style="text-align: right; padding: 5px;"><strong>Subtotal:</strong></td>
              <td style="text-align: right; padding: 5px;"><span t-esc="'%.2f' % (o.amount_untaxed or 0)"/></td>
            </tr>
            <!-- Mostrar cada impuesto por separado usando tax_totals -->
            <!-- tax_totals estructura: {'subtotals': [{'tax_groups': [{'group_name': '...', 'tax_amount_currency': ...}, ...]}]} -->
            <t t-if="o.tax_totals and o.tax_totals.get('subtotals')">
              <t t-foreach="o.tax_totals['subtotals']" t-as="subtotal">
                <t t-if="subtotal.get('tax_groups')">
                  <t t-foreach="subtotal['tax_groups']" t-as="tax_group">
                    <tr>
                      <td style="text-align: right; padding: 5px;"><strong><span t-esc="tax_group.get('group_name', 'Impuesto')"/>:</strong></td>
                      <td style="text-align: right; padding: 5px;"><span t-esc="'%.2f' % (tax_group.get('tax_amount_currency', 0))"/></td>
                    </tr>
                  </t>
                </t>
              </t>
            </t>
            <t t-elif="o.amount_tax and o.amount_tax != 0">
              <!-- Fallback si tax_totals no está disponible: mostrar IVA total -->
              <tr>
                <td style="text-align: right; padding: 5px;"><strong>IVA:</strong></td>
                <td style="text-align: right; padding: 5px;"><span t-esc="'%.2f' % (o.amount_tax or 0)"/></td>
              </tr>
              <!-- Mostrar percepciones/retenciones si existen -->
              <t t-set="percepciones_retenciones" t-value="o.amount_total - o.amount_untaxed - (o.amount_tax or 0)"/>
              <t t-if="percepciones_retenciones and abs(percepciones_retenciones) > 0.01">
                <tr>
                  <td style="text-align: right; padding: 5px;"><strong>Percepciones / Retenciones:</strong></td>
                  <td style="text-align: right; padding: 5px;"><span t-esc="'%.2f' % (percepciones_retenciones)"/></td>
                </tr>
              </t>
            </t>
            <tr style="border-top: 2px solid #d32f2f;">
              <td style="text-align: right; padding: 5px;"><strong>TOTAL A CREDITAR:</strong></td>
              <td style="text-align: right; padding: 5px; color: #d32f2f;"><strong><span t-esc="'%.2f' % (abs(o.amount_total) or 0)"/></strong></td>
            </tr>
          </table>
        </div>
      </div>

      <!-- Información AFIP -->
      <div class="row mt-3">
        <div class="col-12" style="font-size: 12px; text-align: center; border-top: 1px solid #ccc; padding-top: 10px;">
          <strong>INFORMACIÓN AFIP</strong><br/>
          <!-- CAE - Campo opcional: mostrar mensaje por defecto -->
          <em>Nota de Crédito</em><br/>
          Esta nota de crédito cumple con los requisitos de la RG AFIP 4294/2024<br/>
          <small>(CAE disponible cuando se implemente facturación electrónica)</small>
        </div>
      </div>

      <!-- Leyendas legales -->
      <div class="row mt-3 mb-2">
        <div class="col-12" style="font-size: 11px; text-align: center;">
          <strong>NOTA DE CRÉDITO</strong><br/>
          Los importes indicados serán descontados del total facturado.<br/>
          QR Code generado según especificación AFIP
        </div>
      </div>

      <!-- Numeración de página -->
      <div style="position: absolute; bottom: 5mm; right: 10mm; font-size: 10px;">
        Página <span class="page"/> de <span class="topage"/>
      </div>
    </div>
  </t>
</t>
</t>
</t>

