<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <record id="view_account_payment_form_inherit_ar" model="ir.ui.view">
        <field name="name">account.payment.form.inherit.ar</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='main_group']/group[@name='group1']/field[@name='memo']" position="after">
                <field name="ar_register_payment_id" invisible="1"/>
                <field name="ar_register_payment_line_id" invisible="1"/>
                <field name="ar_move_id" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_account_payment_tree_inherit_ar" model="ir.ui.view">
        <field name="name">account.payment.form.inherit.ar</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="ar_register_payment_id" optional="hide"/>
                <field name="ar_move_id" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="view_account_payment_search_inherit_ar" model="ir.ui.view">
        <field name="name">account.payment.search.inherit.ar</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_search"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="ar_register_payment_id"/>
                <field name="ar_move_id" />
            </xpath>
            <!--xpath expr="//search" position="inside">
                <separator/>
                <filter string="AR Payment Orders" name="ar_payment_orders" domain="[('ar_register_payment_id', '!=', False)]"/>
            </xpath-->
            <xpath expr="//search" position="inside">
                <filter string="AR Payment Order"
                        name="group_by_ar_payment"
                        context="{'group_by': 'ar_register_payment_id'}"/>
                <filter string="AR: Move" name="group_by_move" context="{'group_by': 'ar_move_id'}"/>
            </xpath>
        </field>
    </record>

    </data>
</odoo>
