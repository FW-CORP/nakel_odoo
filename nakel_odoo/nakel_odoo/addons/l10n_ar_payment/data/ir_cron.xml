<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="ir_cron_cleanup_ar_register_payments" model="ir.cron">
        <field name="name">Cleanup Unused AR Register Payments</field>
        <field name="model_id" ref="model_ar_register_payments"/>
        <field name="state">code</field>
        <field name="code">model._cron_cleanup_unused_ar_payments()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field name="nextcall" eval="(DateTime.now() + relativedelta(hour=3, minute=0, second=0))"/>
    </record>

</odoo>
