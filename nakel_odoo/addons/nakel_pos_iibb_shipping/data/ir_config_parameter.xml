<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Prueba staging: IIBB / pivot usa provincia de partner_shipping_id.
         Con True, las facturas POS toman entrega = Dirección PV del diario. -->
    <record id="icp_nakel_pos_iibb_shipping_enable" model="ir.config_parameter">
        <field name="key">nakel_pos_iibb_shipping.enable</field>
        <!-- Tras instalar en staging, dejar True. En producción: False. -->
        <field name="value">True</field>
    </record>
</odoo>
