<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!--
            Alcance informe gerencia: solo facturas y notas de crédito de cliente publicadas.
            Sin filtro por invoice_user_id. Multi-compañía alineado al usuario.
            Si el usuario también es vendedor, la regla de clientes_cc_detalle se combina en OR
            y no reduce el alcance para FC/NC de terceros.
        -->
        <record id="rule_account_move_cc_informe_gerencia" model="ir.rule">
            <field name="name">Nakel CC informe: FC/NC cliente publicadas (gerencia)</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="domain_force">['&amp;', '&amp;', '|', ('company_id', '=', False), ('company_id', 'in', company_ids), ('move_type', 'in', ('out_invoice', 'out_refund')), ('state', '=', 'posted')]</field>
            <field name="groups" eval="[(4, ref('group_cc_informe_gerencia'))]"/>
        </record>
        <record id="rule_account_move_line_cc_informe_gerencia" model="ir.rule">
            <field name="name">Nakel CC informe: líneas de FC/NC (gerencia)</field>
            <field name="model_id" ref="account.model_account_move_line"/>
            <field name="domain_force">['&amp;', '&amp;', '|', ('company_id', '=', False), ('company_id', 'in', company_ids), ('move_id.move_type', 'in', ('out_invoice', 'out_refund')), ('move_id.state', '=', 'posted')]</field>
            <field name="groups" eval="[(4, ref('group_cc_informe_gerencia'))]"/>
        </record>
    </data>
</odoo>
