<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Misma acción que abre el asistente: target inline para entrar desde menú sin popup. -->
        <record id="action_clientes_cc_informe_wizard_menu" model="ir.actions.act_window">
            <field name="name">Informe de cuentas corrientes clientes</field>
            <field name="res_model">clientes.cc.informe.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_clientes_cc_informe_wizard_form"/>
            <field name="target">current</field>
        </record>

        <record id="action_act_window_clientes_cc_gerencia" model="ir.actions.act_window">
            <field name="name">Detalle CC clientes (gerencia)</field>
            <field name="res_model">account.move</field>
            <field name="search_view_id" ref="account.view_account_invoice_filter"/>
            <field name="view_mode">list,pivot,graph,form</field>
            <field name="domain">[('move_type', 'in', ('out_invoice', 'out_refund')), ('state', '=', 'posted')]</field>
            <field name="context" eval="{
                'search_default_posted': 1,
                'pivot_row_groupby': ['invoice_user_id', 'commercial_partner_id'],
                'pivot_column_groupby': ['payment_state'],
                'pivot_measures': ['amount_residual', 'amount_total_signed'],
            }"/>
            <field name="target">current</field>
        </record>

        <record id="action_act_window_clientes_cc_gerencia_view_list" model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="clientes_cc_detalle.view_account_move_tree_my_sales"/>
            <field name="act_window_id" ref="action_act_window_clientes_cc_gerencia"/>
        </record>
        <record id="action_act_window_clientes_cc_gerencia_view_pivot" model="ir.actions.act_window.view">
            <field name="sequence" eval="2"/>
            <field name="view_mode">pivot</field>
            <field name="view_id" ref="clientes_cc_detalle.view_account_move_pivot_my_sales"/>
            <field name="act_window_id" ref="action_act_window_clientes_cc_gerencia"/>
        </record>
        <record id="action_act_window_clientes_cc_gerencia_view_graph" model="ir.actions.act_window.view">
            <field name="sequence" eval="3"/>
            <field name="view_mode">graph</field>
            <field name="view_id" ref="clientes_cc_detalle.view_account_move_graph_my_sales"/>
            <field name="act_window_id" ref="action_act_window_clientes_cc_gerencia"/>
        </record>

        <menuitem
            id="menu_clientes_cc_informe_gerencia"
            name="Informe de cuentas corrientes clientes"
            parent="sale.sale_order_menu"
            action="action_clientes_cc_informe_wizard_menu"
            sequence="46"
            groups="base.group_system,clientes_cc_informe.group_cc_informe_gerencia"
        />
    </data>
</odoo>
