<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Demo Journal configured for Tucuman TXT -->

    <record id="journal_tucuman_txt_demo" model="account.journal">
        <field name="name">Journal Tucuman TXT Demo</field>
        <field name="code">TXTUC</field>
        <field name="type">general</field>
        <field name="tax_settlement">allow_per_line</field>
        <field name="settlement_partner_id" ref="partner_tucuman_demo_1"/>
        <field name="settlement_tax">iibb_tucuman</field>
        <field name="settlement_account_tag_ids" eval="[(6, 0, [ref('l10n_ar_txt_tucuman.account_tax_tag_tucuman_demo')])]"/>
        <field name="company_id" ref="base.company_ri"/>
    </record>

</odoo>
