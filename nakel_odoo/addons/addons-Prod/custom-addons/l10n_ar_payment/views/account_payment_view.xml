<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <record id="view_ar_account_payment_form_inherit" model="ir.ui.view">
        <field name="name">ar.account.payment.form.inherit</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='main_group']/group[@name='group1']/field[@name='memo']" position="after">
                <field name="ar_register_payment_id" invisible="1"/>
                <field name="ar_register_payment_line_id" invisible="1"/>
            </xpath>
        </field>
    </record>

    </data>
</odoo>
