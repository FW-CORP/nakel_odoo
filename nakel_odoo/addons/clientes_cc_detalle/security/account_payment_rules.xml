<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Solo pagos que impactan FC/NC donde el usuario es comercial en cabecera. -->
        <record id="rule_account_payment_cc_my_sales" model="ir.rule">
            <field name="name">Nakel CC: pagos ligados a mis facturas/NC</field>
            <field name="model_id" ref="account.model_account_payment"/>
            <!--
                Solo group_cc_payment_restricted (no group_cc_my_sales): administradores y
                contadores suelen tener CC mis ventas para probar menús pero deben ver todos los pagos.
                El hook sync_cc_payment_restricted_groups asigna este grupo solo a comerciales sin
                Ajustes del sistema ni Contabilidad / Facturación.
            -->
            <field name="domain_force">['|', '|', ('partner_type', '=', 'supplier'), ('create_uid', '=', user.id), ('reconciled_invoice_ids.invoice_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(6, 0, [ref('clientes_cc_detalle.group_cc_payment_restricted')])]"/>
        </record>
    </data>
</odoo>
