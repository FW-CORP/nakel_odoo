<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Solo pagos que impactan FC/NC donde el usuario es comercial en cabecera. -->
        <record id="rule_account_payment_cc_my_sales" model="ir.rule">
            <field name="name">Nakel CC: pagos ligados a mis facturas/NC</field>
            <field name="model_id" ref="account.model_account_payment"/>
            <!--
                Solo aplica a usuarios del grupo «Nakel CC / mis ventas» (group_cc_my_sales).
                NO incluir Ventas / Vendedor ni Responsable: los contadores suelen tener esos grupos y
                la regla chocaba con lecturas estándar (smartbutton Pagos, borradores RE-X, OP, etc.).
                Los vendedores sin contabilidad no debían ver todos los pagos: se revocó el perm_read
                extra en account_payment_access.xml (solo queda lectura explícita para el grupo CC).
            -->
            <field name="domain_force">['|', '|', ('partner_type', '=', 'supplier'), ('create_uid', '=', user.id), ('reconciled_invoice_ids.invoice_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(6, 0, [ref('clientes_cc_detalle.group_cc_my_sales')])]"/>
        </record>
    </data>
</odoo>
