<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Lectura de cobros para ver desglose desde CC «mis ventas» (sin dar altas/bajas). -->
        <record id="access_clientes_cc_account_payment_read" model="ir.model.access">
            <field name="name">clientes_cc account.payment read (Nakel CC)</field>
            <field name="model_id" ref="account.model_account_payment"/>
            <field name="group_id" ref="clientes_cc_detalle.group_cc_my_sales"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>
        <record id="access_clientes_cc_account_payment_read_salesman" model="ir.model.access">
            <field name="name">clientes_cc account.payment read (vendedor)</field>
            <field name="model_id" ref="account.model_account_payment"/>
            <field name="group_id" ref="sales_team.group_sale_salesman"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>
        <record id="access_clientes_cc_account_payment_read_manager" model="ir.model.access">
            <field name="name">clientes_cc account.payment read (responsable ventas)</field>
            <field name="model_id" ref="account.model_account_payment"/>
            <field name="group_id" ref="sales_team.group_sale_manager"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>
    </data>
</odoo>
