<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Misma semántica que el smart button / menú. Regla para AMBOS grupos:
             sin esto, el perm_read de group_sale_salesman expondría todos los asientos. -->
        <record id="rule_account_move_cc_my_sales" model="ir.rule">
            <field name="name">Nakel CC: facturas cliente solo comercial actual</field>
            <field name="model_id" ref="account.model_account_move"/>
            <!-- Incluye asientos de cobros (`origin_payment_id`) para poder abrir el pago desde la FC. -->
            <!-- Sin eval: al cargar datos, safe_eval no define `user` (solo en runtime de la regla). -->
            <field name="domain_force">['|', '&amp;', ('move_type', 'in', ('out_invoice', 'out_refund')), ('state', '=', 'posted'), ('invoice_user_id', '=', user.id), '&amp;', ('origin_payment_id', '!=', False), ('origin_payment_id.reconciled_invoice_ids.invoice_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('clientes_cc_detalle.group_cc_my_sales')), (4, ref('sales_team.group_sale_salesman'))]"/>
        </record>
        <record id="rule_account_move_line_cc_my_sales" model="ir.rule">
            <field name="name">Nakel CC: líneas de facturas del comercial actual</field>
            <field name="model_id" ref="account.model_account_move_line"/>
            <field name="domain_force">['|', '&amp;', ('move_id.move_type', 'in', ('out_invoice', 'out_refund')), ('move_id.state', '=', 'posted'), ('move_id.invoice_user_id', '=', user.id), '&amp;', ('move_id.origin_payment_id', '!=', False), ('move_id.origin_payment_id.reconciled_invoice_ids.invoice_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('clientes_cc_detalle.group_cc_my_sales')), (4, ref('sales_team.group_sale_salesman'))]"/>
        </record>
    </data>
</odoo>
