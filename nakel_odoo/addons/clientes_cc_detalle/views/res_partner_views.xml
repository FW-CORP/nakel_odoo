<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Lista Contactos: columnas opcionales, mismo criterio que menú CC (sin deuda cruzada por otro vendedor). -->
        <record id="view_partner_tree_cc_my_sales" model="ir.ui.view">
            <field name="name">res.partner.tree.cc.my.sales</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//list" position="inside">
                    <field
                        name="cc_my_sales_currency_id" column_invisible="1"/>
                    <field
                        name="cc_my_sales_residual"
                        optional="show"
                        sum="Total (mis ventas)"
                        groups="sales_team.group_sale_salesman,sales_team.group_sale_manager,clientes_cc_detalle.group_cc_my_sales"
                    />
                    <field
                        name="cc_my_sales_residual_opening"
                        optional="hide"
                        sum="Total saldo anterior"
                        groups="sales_team.group_sale_salesman,sales_team.group_sale_manager,clientes_cc_detalle.group_cc_my_sales"
                    />
                    <field
                        name="cc_my_sales_state"
                        optional="show"
                        widget="badge"
                        decoration-success="cc_my_sales_state in ('ok', 'none')"
                        decoration-warning="cc_my_sales_state == 'due'"
                        decoration-danger="cc_my_sales_state == 'overdue'"
                        decoration-info="cc_my_sales_state == 'credit'"
                        groups="sales_team.group_sale_salesman,sales_team.group_sale_manager,clientes_cc_detalle.group_cc_my_sales"
                    />
                </xpath>
            </field>
        </record>

        <record id="view_partner_form_cc_my_sales" model="ir.ui.view">
            <field name="name">res.partner.form.cc.my.sales</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                    <field name="cc_my_sales_currency_id" invisible="1"/>
                    <button
                        name="action_open_cc_my_sales"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-usd"
                        groups="clientes_cc_detalle.group_cc_my_sales"
                    >
                        <!-- Saldo &gt;= 0: pendiente de cobro del subconjunto (0 = nada pendiente) -->
                        <field
                            name="cc_my_sales_residual"
                            widget="statinfo"
                            string="Cuenta corriente cliente"
                            invisible="cc_my_sales_residual &lt; 0"
                        />
                        <!-- Saldo &lt; 0: crédito a favor del cliente en este subconjunto (en rojo) -->
                        <field
                            name="cc_my_sales_residual"
                            widget="statinfo"
                            string="Cuenta corriente cliente"
                            class="text-danger"
                            invisible="cc_my_sales_residual &gt;= 0"
                        />
                    </button>
                </xpath>
                <xpath expr="//div[hasclass('oe_button_box')]" position="after">
                    <group
                        string="CC mis ventas — saldo anterior al corte"
                        invisible="cc_my_sales_residual_opening == 0"
                        groups="clientes_cc_detalle.group_cc_my_sales"
                    >
                        <field
                            name="cc_my_sales_residual_opening"
                            readonly="1"
                            string="FC/NC anteriores a la fecha de corte (parámetro sistema)"
                        />
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
