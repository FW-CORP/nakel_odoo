<!-- Remito Nakel: basic_layout (un solo encabezado Nakel), cantidades desde move, valor desde OV -->
<t t-name="stock.report_delivery_document_nakel_2024">
<t t-call="web.html_container">
<t t-foreach="docs" t-as="o">
<t t-call="web.basic_layout">
    <!-- Pie con numeración: wkhtmltopdf subst() rellena span.page / span.topage en cada hoja (como factura Nakel). -->
    <div class="footer o_nakel_page_footer" style="font-size:8px; text-align:right; color:#000; padding:2px 2mm 0 2mm; line-height:1.2;">
      Hoja <span class="page"/>/<span class="topage"/>
    </div>
    <style type="text/css">
      /* Márgenes reales: report.paperformat del reporte (A4 Nakel Factura Ajustado). No duplicar @page margin. */
      @page { size: A4 portrait; margin: 0; }
      html, body {
        margin: 0 !important;
        padding: 0 !important;
      }
      article.o_report_layout_standard,
      .o_report_layout_standard {
        padding-top: 0 !important;
        margin-top: 0 !important;
      }
      .nakel-invoice-page {
        padding-top: 0;
        padding-bottom: 8mm;
        box-sizing: border-box;
      }
      .nakel-fiscal-header.row {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
      }
      .nakel-fiscal-header .nakel-doc-letter {
        display: flex;
        align-items: center;
        justify-content: center;
        align-self: stretch;
      }
      .nakel-fiscal-header .nakel-doc-letter-inner {
        font-size: 24px;
        font-weight: 700;
        line-height: 1;
      }
      table.nakel-lines-table thead {
        display: table-header-group;
      }
      table.nakel-lines-table tbody tr {
        page-break-inside: avoid;
        break-inside: avoid;
      }
      .nakel-totals-qr-block {
        page-break-inside: avoid;
        break-inside: avoid;
      }
    </style>
    <t t-set="report_date" t-value="o.date_done or o.scheduled_date"/>
    <t t-set="report_number" t-value="o.name.replace('/OUT/', '/').replace('/PICK/', '/')"/>
    <t t-set="formatted_vat" t-value="o.company_id.partner_id.l10n_ar_formatted_vat if o.company_id.partner_id and o.company_id.partner_id._fields.get('l10n_ar_formatted_vat') else o.company_id.vat"/>
    <t t-set="move_list" t-value="o.move_ids_without_package or []"/>
    <t t-set="cur_total" t-value="o.sale_id.currency_id if o.sale_id else o.company_id.currency_id"/>
    <t t-set="total_mercaderia" t-value="0.0"/>
    <!-- Dirección impresa: misma idea que factura (OV → dirección de entrega; si no, dirección del picking). -->
    <t t-set="partner_entrega" t-value="o.sale_id.partner_shipping_id if (o.sale_id and o.sale_id._fields.get('partner_shipping_id') and o.sale_id.partner_shipping_id) else False"/>
    <t t-set="partner_direccion" t-value="partner_entrega if (partner_entrega and (partner_entrega.street or partner_entrega.street2 or partner_entrega.city or partner_entrega.state_id or partner_entrega.zip)) else o.partner_id"/>
    <div class="page nakel-invoice-page" style="font-size:12px; color:#202020; padding:0 2mm 0 2mm; position:relative;">

      <div class="row nakel-fiscal-header" style="border-bottom:1px solid #111; padding-bottom:6px; margin-bottom:4px;">
        <div class="col-4" style="font-size:10px; line-height:1.3;">
          <t t-if="o.company_id.logo">
            <div style="margin-bottom:4px;">
              <img t-att-src="image_data_uri(o.company_id.logo)" style="max-height:38px;" alt="Logo"/>
            </div>
          </t>
          <div style="font-size:13px;"><strong t-field="o.company_id.name"/></div>
          <div><span t-field="o.company_id.street"/> - <span t-field="o.company_id.city"/></div>
          <div><span t-field="o.company_id.state_id.name"/> - <span t-field="o.company_id.zip"/></div>
          <t t-if="o.company_id.website"><div><span t-field="o.company_id.website"/></div></t>
        </div>
        <div class="col-2 text-center nakel-doc-letter">
          <div class="nakel-doc-letter-inner">R</div>
        </div>
        <div class="col-6" style="font-size:14px; line-height:1.3;">
          <div style="width:74mm; margin-left:auto; text-align:left;">
            <div style="font-weight:700;">Remito</div>
            <div>Nro: <span t-esc="report_number"/></div>
            <div>Fecha: <t t-if="report_date"><span t-esc="env['ir.qweb.field.date'].value_to_html(report_date, {})"/></t></div>
            <div>CUIT: <span t-esc="formatted_vat"/></div>
            <div>IVA Responsable Inscripto</div>
            <t t-if="o.company_id.l10n_ar_gross_income_number">
              <div>IIBB: <span t-field="o.company_id.l10n_ar_gross_income_number"/></div>
            </t>
            <t t-if="o.company_id.l10n_ar_afip_start_date">
              <div>Inicio de actividades: <span t-field="o.company_id.l10n_ar_afip_start_date" t-options="{'widget': 'date'}"/></div>
            </t>
          </div>
        </div>
      </div>

      <h5 style="margin:2px 0 6px 0; font-size:13px;"><strong>DATOS DEL DESTINATARIO</strong></h5>
      <div class="row" style="margin-bottom:8px; font-size:12px; line-height:1.45;">
        <div class="col-6">
          <t t-if="o.partner_id.name">Nombre: <span t-field="o.partner_id.name"/></t><br/>
          <t t-if="o.partner_id.vat">CUIT/DNI: <span t-field="o.partner_id.vat"/></t><br/>
          <t t-if="o.partner_id.phone">Teléfono: <span t-field="o.partner_id.phone"/></t><br/>
          <t t-if="o.partner_id.email">e-mail: <span t-field="o.partner_id.email"/></t><br/>
        </div>
        <div class="col-6">
          <div style="width:74mm; max-width:100%; margin-left:auto; text-align:left;">
            <t t-if="partner_direccion and (partner_direccion.street or partner_direccion.street2 or partner_direccion.city or partner_direccion.state_id or partner_direccion.zip)">
              <div>
                Dirección:
                <span t-if="partner_direccion.street" t-field="partner_direccion.street"/>
                <t t-if="partner_direccion.street2"> - <span t-field="partner_direccion.street2"/></t>
              </div>
              <t t-if="partner_direccion.city"><div>Localidad: <span t-field="partner_direccion.city"/></div></t>
              <t t-if="partner_direccion.state_id"><div>Provincia: <span t-field="partner_direccion.state_id.name"/></div></t>
              <t t-if="partner_direccion.zip"><div>C.P.: <span t-field="partner_direccion.zip"/></div></t>
            </t>
          </div>
        </div>
      </div>

      <h5 class="mt-2 mb-1"><strong>INFORMACIÓN DEL PEDIDO</strong></h5>
      <div class="row mb-2">
        <div class="col-12">
          Nº Pedido: <span t-field="o.origin"/><br/>
          Fecha Pedido: <span t-field="o.scheduled_date" t-options="{'widget': 'date'}"/><br/>
          <t t-if="o.sale_id and o.sale_id.client_order_ref">Referencia: <span t-field="o.sale_id.client_order_ref"/></t>
        </div>
      </div>

      <h5 class="mt-2 mb-1"><strong>DETALLE DE MERCADERÍA</strong></h5>
      <t t-if="move_list">
        <div class="row mt-3 mb-2">
          <div class="col-12">
            <table class="table table-sm nakel-lines-table" style="border-collapse: collapse; width: 100%; margin-bottom: 20px;">
              <thead>
                <tr>
                  <th style="border: 1px solid #000; padding: 8px; background-color: #f8f9fa;">Código</th>
                  <th style="border: 1px solid #000; padding: 8px; background-color: #f8f9fa;">Descripción</th>
                  <th style="border: 1px solid #000; padding: 8px; background-color: #f8f9fa;">Cantidad</th>
                  <th style="border: 1px solid #000; padding: 8px; background-color: #f8f9fa;">Valor</th>
                </tr>
              </thead>
              <tbody>
                <t t-foreach="move_list" t-as="l">
                  <t t-set="qty_ml" t-value="sum(l.move_line_ids.mapped('quantity')) if l.move_line_ids else 0.0"/>
                  <t t-set="qty_show" t-value="qty_ml if qty_ml else (l.quantity if l.quantity else l.product_uom_qty)"/>
                  <!-- Valor: usar línea de OV si existe; fallback por producto cuando falta o qty=0 (evita imprimir '—' por división en cero). -->
                  <t t-set="so_fallback" t-value="o.sale_id or (env['sale.order'].search([('name', '=', o.origin)], limit=1) if o.origin else False)"/>
                  <t t-set="sol" t-value="l.sale_line_id or (so_fallback.order_line.filtered(lambda x: x.product_id == l.product_id)[:1] if so_fallback else False)"/>
                  <t t-set="sol_qty" t-value="float(sol.product_uom_qty or 0.0) if sol else 0.0"/>
                  <t t-set="unit_net" t-value="(float(sol.price_unit or 0.0) * (1.0 - (float(sol.discount or 0.0) / 100.0))) if sol else 0.0"/>
                  <t t-set="line_val" t-value="(unit_net * float(qty_show or 0.0)) if unit_net else ((float(sol.price_subtotal or 0.0) * (float(qty_show or 0.0) / sol_qty)) if (sol and sol_qty) else 0.0)"/>
                  <t t-set="total_mercaderia" t-value="total_mercaderia + line_val"/>
                  <tr>
                    <td style="border: 1px solid #000; padding: 8px; vertical-align: top;"><span t-field="l.product_id.default_code"/></td>
                    <td style="border: 1px solid #000; padding: 8px; vertical-align: top;"><span t-field="l.product_id.name"/></td>
                    <td style="border: 1px solid #000; padding: 8px; vertical-align: top;" class="text-center"><span t-esc="qty_show"/></td>
                    <td style="border: 1px solid #000; padding: 8px; vertical-align: top;" class="text-right">
                      <t t-if="sol and (unit_net or (sol_qty and sol.price_subtotal))">
                        <span t-esc="(sol.currency_id.symbol if (sol and sol.currency_id) else cur_total.symbol)"/>
                        <span t-esc="'%.2f' % line_val"/>
                      </t>
                      <t t-else="">—</t>
                    </td>
                  </tr>
                </t>
                <tr>
                  <td colspan="3" style="border: 1px solid #000; padding: 8px; text-align: right;"><strong>TOTAL</strong></td>
                  <td style="border: 1px solid #000; padding: 8px; text-align: right;">
                    <strong>
                      <span t-field="cur_total.symbol"/>
                      <span t-esc="'%.2f' % total_mercaderia"/>
                    </strong>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </t>

      <div class="row mt-3 nakel-totals-qr-block">
        <div class="col-6">
          <div style="text-align: center; border: 1px solid #ccc; padding: 10px;">
            <div style="width: 150px; height: 150px; border: 1px dashed #ccc; margin: 0 auto; display: flex; align-items: center; justify-content: center;">
              <small>QR Code<br/>(disponible en facturación electrónica)</small>
            </div>
            <br/>
            <small>QR Code con información fiscal según RG AFIP 4294/2024</small>
          </div>
        </div>
        <div class="col-6">
          <div style="border: 1px solid #ccc; padding: 10px; min-height: 150px;">
            <strong>INFORMACIÓN DE TRANSPORTE</strong><br/>
            <t t-if="o.carrier_id">
              Transportista: <span t-field="o.carrier_id.name"/><br/>
            </t>
            <t t-if="o.carrier_tracking_ref">
              Nº Guía: <span t-field="o.carrier_tracking_ref"/><br/>
            </t>
            <br/>
            <strong>OBSERVACIONES</strong><br/>
            <span t-field="o.note"/>
          </div>
        </div>
      </div>

      <div class="row mt-4">
        <div class="col-6">
          <div style="border-top: 1px solid #000; padding-top: 10px; text-align: center;">
            <strong>FIRMA Y ACLARACIÓN</strong><br/>
            <br/><br/><br/>
            _________________________
          </div>
        </div>
        <div class="col-6">
          <div style="border-top: 1px solid #000; padding-top: 10px; text-align: center;">
            <strong>RECIBÍ CONFORME</strong><br/>
            <br/><br/><br/>
            Firma, Aclaración y DNI<br/>
            Fecha: ___/___/___
          </div>
        </div>
      </div>

      <div class="row mt-3 mb-2">
        <div class="col-12">
          <strong>CONDICIONES:</strong><br/>
          Se requiere DNI para la entrega. Verificar cantidad y estado. Reclamos únicamente dentro de las 24 hs.
        </div>
      </div>

      <div class="row mt-3">
        <div class="col-12" style="font-size: 10px; text-align: center; border-top: 1px solid #ccc; padding-top: 10px;">
          <strong>CONDICIONES LEGALES</strong><br/>
          Este remito cumple con los requisitos de la RG AFIP 4294/2024.<br/>
          Documento de transporte obligatorio según normativa vigente.
        </div>
      </div>
    </div>
</t>
</t>
</t>
</t>
