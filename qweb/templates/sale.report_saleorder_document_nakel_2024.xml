<!-- Cotización / pedido Nakel 2024: mismo lenguaje visual que factura (basic_layout, tabla, totales). Sin bloque AFIP/QR. -->
<t t-name="sale.report_saleorder_document_nakel_2024">
  <t t-call="web.basic_layout">
    <!-- Numeración wkhtmltopdf: en header puede superponerse; en footer queda al pie real -->
    <div class="footer o_nakel_page_footer" style="font-size:8px; text-align:right; color:#000; padding:2px 2mm 0 2mm; line-height:1.2;">
      Hoja <span class="page"></span>/<span class="topage"></span>
    </div>
    <style type="text/css">
      @page { size: A4 portrait; }
      article.o_report_layout_standard,
      .o_report_layout_standard {
        padding-top: 0 !important;
        margin-top: 0 !important;
      }
      .nakel-invoice-page {
        padding-top: 0;
        padding-bottom: 8mm;
        box-sizing: border-box;
      }
      .nakel-fiscal-header.row {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
      }
      .nakel-fiscal-header .nakel-doc-letter {
        display: flex;
        align-items: center;
        justify-content: center;
        align-self: stretch;
      }
      .nakel-fiscal-header .nakel-doc-letter-inner {
        /* "COTIZACIÓN"/"PEDIDO DE VENTA" no debe deformarse en la columna central */
        font-size: 18px;
        font-weight: 800;
        line-height: 1.05;
        letter-spacing: 0.3px;
        text-transform: uppercase;
        text-align: center;
        word-break: normal;
        overflow-wrap: anywhere;
      }
      table.nakel-lines-table {
        page-break-inside: auto;
        border-collapse: collapse;
        table-layout: fixed;
        width: 100%;
      }
      table.nakel-lines-table thead {
        display: table-header-group;
      }
      table.nakel-lines-table tbody tr {
        page-break-inside: avoid;
        break-inside: avoid;
      }
      table.nakel-lines-table th.nakel-col-code,
      table.nakel-lines-table td.nakel-col-code {
        font-size: 13px;
        font-weight: 500;
        line-height: 1.3;
      }
      table.nakel-lines-table th.nakel-col-desc,
      table.nakel-lines-table td.nakel-col-desc {
        font-size: 13px;
        line-height: 1.3;
      }
      table.nakel-lines-table th.nakel-col-qty,
      table.nakel-lines-table td.nakel-col-qty {
        font-size: 13px;
        font-weight: 600;
        line-height: 1.3;
      }
      table.nakel-lines-table th.nakel-col-price,
      table.nakel-lines-table td.nakel-col-price {
        font-size: 13px;
        font-weight: 600;
        line-height: 1.3;
      }
      table.nakel-lines-table th.nakel-col-disc,
      table.nakel-lines-table td.nakel-col-disc {
        font-size: 12px;
        font-weight: 600;
        line-height: 1.3;
      }
      table.nakel-lines-table th.nakel-col-tax {
        font-size: 13px;
        font-weight: 600;
        line-height: 1.3;
      }
      table.nakel-lines-table td.nakel-col-tax-body {
        font-size: 8px;
        font-weight: 400;
        line-height: 1.25;
      }
      table.nakel-lines-table th.nakel-col-sub,
      table.nakel-lines-table td.nakel-col-sub {
        font-size: 13px;
        font-weight: 700;
        line-height: 1.3;
      }
      .nakel-quote-meta-block {
        page-break-inside: avoid;
        break-inside: avoid;
      }
    </style>

    <t t-set="lines_to_report" t-value="doc._get_order_lines_to_report()"/>
    <!-- Sin True/False ni any() en t-value: el evaluador QWeb puede fallar (NoneType not callable). -->
    <t t-set="display_discount" t-value="0"/>
    <t t-foreach="lines_to_report or []" t-as="l_disc">
      <t t-if="l_disc.discount">
        <t t-set="display_discount" t-value="1"/>
      </t>
    </t>
    <t t-set="partner_afip_resp" t-value="0"/>
    <t t-if="doc.partner_id and doc.partner_id._fields.get('l10n_ar_afip_responsibility_type_id') and doc.partner_id.l10n_ar_afip_responsibility_type_id">
      <t t-set="partner_afip_resp" t-value="doc.partner_id.l10n_ar_afip_responsibility_type_id"/>
    </t>
    <t t-set="receptor_condicion_leyenda" t-value="'Cliente'"/>
    <t t-if="partner_afip_resp">
      <t t-set="receptor_condicion_leyenda" t-value="partner_afip_resp.name"/>
    </t>
    <t t-set="titulo_documento" t-value="'COTIZACIÓN'"/>
    <t t-if="doc.state not in ('draft', 'sent')">
      <t t-set="titulo_documento" t-value="'PEDIDO DE VENTA'"/>
    </t>
    <t t-set="company_website" t-value="doc.company_id.website or 'www.nakel.net.ar'"/>
    <t t-set="company_email" t-value="doc.company_id.email or 'info@nakel.net.ar'"/>
    <t t-set="company_phone" t-value="doc.company_id.phone or '297 5415807'"/>
    <t t-set="formatted_vat" t-value="doc.company_id.vat"/>
    <t t-if="doc.company_id.partner_id and doc.company_id.partner_id._fields.get('l10n_ar_formatted_vat')">
      <t t-set="formatted_vat" t-value="doc.company_id.partner_id.l10n_ar_formatted_vat"/>
    </t>

    <div class="page nakel-invoice-page" style="font-size:12px; color:#202020; padding:0 2mm 0 2mm; position:relative;">
      <!-- Encabezado sobrio en 2 columnas: Nakel (izq) + Cliente/Datos (der) -->
      <div class="row" style="border-bottom:1px solid #111; padding:0 0 6px; margin:0 0 6px 0;">
        <div class="col-6" style="font-size:10px; line-height:1.25;">
          <t t-if="doc.company_id.logo">
            <div style="margin:0 0 3px 0;">
              <img t-att-src="image_data_uri(doc.company_id.logo)" style="max-height:44px;" alt="Logo"/>
            </div>
          </t>
          <div style="font-size:14px; line-height:1.15;"><strong t-field="doc.company_id.name"/></div>
          <div><span t-field="doc.company_id.street"/> - <span t-field="doc.company_id.city"/></div>
          <div><span t-field="doc.company_id.state_id.name"/> - <span t-field="doc.company_id.zip"/></div>
        </div>
        <div class="col-6" style="text-align:right;">
          <div style="display:inline-block; text-align:left; width:92mm; border:1px solid #e0e0e0; padding:7px 8px; background:#fff;">
            <div style="text-align:right; font-weight:800; font-size:16px; letter-spacing:0.4px; margin-bottom:4px; white-space:nowrap;">
              <span t-out="titulo_documento"/>
            </div>
            <div style="font-size:10px; line-height:1.35;">
              <div><strong>Nro:</strong> <span t-field="doc.name"/></div>
              <div><strong>Fecha:</strong> <span t-field="doc.date_order" t-options="{'widget': 'date'}"/></div>
              <t t-if="doc.validity_date and doc.state in ('draft', 'sent')">
                <div><strong>Válida hasta:</strong> <span t-field="doc.validity_date" t-options="{'widget': 'date'}"/></div>
              </t>
              <t t-if="doc.user_id"><div><strong>Comercial:</strong> <span t-field="doc.user_id.name"/></div></t>
              <div style="border-top:1px solid #eee; margin:6px 0;"/>
              <div style="font-weight:700;"><span t-field="doc.partner_id.name"/></div>
              <t t-if="doc.partner_id.vat"><div>CUIT/DNI: <span t-field="doc.partner_id.vat"/></div></t>
              <t t-if="doc.partner_id.street or doc.partner_id.street2">
                <div>
                  <span t-if="doc.partner_id.street" t-field="doc.partner_id.street"/>
                  <t t-if="doc.partner_id.street2"> - <span t-field="doc.partner_id.street2"/></t>
                </div>
              </t>
              <t t-if="doc.partner_id.city or doc.partner_id.state_id">
                <div>
                  <t t-if="doc.partner_id.city"><span t-field="doc.partner_id.city"/></t>
                  <t t-if="doc.partner_id.state_id">, <span t-field="doc.partner_id.state_id.name"/></t>
                  <t t-if="doc.partner_id.zip"> (<span t-field="doc.partner_id.zip"/>)</t>
                </div>
              </t>
              <t t-if="doc.client_order_ref"><div>Ref.: <span t-field="doc.client_order_ref"/></div></t>
            </div>
          </div>
        </div>
      </div>

      <t t-if="doc.payment_term_id or doc.user_id">
        <div class="row" style="font-size:10px; margin-bottom:8px;">
          <div class="col-6">
            <t t-if="doc.payment_term_id"><strong>Plazo de pago:</strong> <span t-field="doc.payment_term_id.name"/></t>
          </div>
          <div class="col-6" style="text-align:right;">
            <t t-if="doc.user_id"><strong>Comercial:</strong> <span t-field="doc.user_id.name"/></t>
          </div>
        </div>
      </t>

      <div style="font-size:13px; font-weight:700; margin:6px 0 6px;">DETALLE</div>
      <table class="table table-sm nakel-lines-table" style="margin-bottom:12px; font-size:10px;">
        <thead>
          <tr>
            <th class="nakel-col-code" style="border:1px solid #111; padding:5px 3px; background:#fff; width:8%;">Código</th>
            <th class="nakel-col-desc" style="border:1px solid #111; padding:5px 4px; background:#fff; width:34%;">Descripción</th>
            <th class="nakel-col-qty" style="border:1px solid #111; padding:5px 3px; background:#fff; text-align:center; width:8%;">Cantidad</th>
            <th class="nakel-col-price" style="border:1px solid #111; padding:5px 2px; background:#fff; text-align:right; width:10%;">Precio Unit.</th>
            <th t-if="display_discount" class="nakel-col-disc" style="border:1px solid #111; padding:5px 2px; background:#fff; text-align:right; width:7%;">Dto.%</th>
            <th class="nakel-col-tax" style="border:1px solid #111; padding:5px 4px; background:#fff; text-align:right; width:19%;">Impuestos</th>
            <th class="nakel-col-sub" style="border:1px solid #111; padding:5px 3px; background:#fff; text-align:right; width:11%;">Subtotal</th>
          </tr>
        </thead>
        <tbody>
          <t t-set="nakel_colspan" t-value="6 + display_discount"/>
          <t t-foreach="lines_to_report" t-as="line">
            <tr t-if="line.display_type == 'line_section' or line.display_type == 'line_combo'">
              <td t-att-colspan="nakel_colspan" style="border:1px solid #111; padding:6px; font-weight:700; background:#f5f5f5;">
                <span t-field="line.name" t-options="{'widget': 'text'}"/>
              </td>
            </tr>
            <tr t-elif="line.display_type == 'line_note'">
              <td t-att-colspan="nakel_colspan" style="border:1px solid #111; padding:6px; font-style:italic; background:#fafafa;">
                <span t-field="line.name" t-options="{'widget': 'text'}"/>
              </td>
            </tr>
            <tr t-elif="not line.display_type">
              <td class="nakel-col-code" style="border:1px solid #111; padding:5px 3px; vertical-align:top; word-wrap:break-word;">
                <span t-if="line.product_id" t-field="line.product_id.default_code"/>
              </td>
              <td class="nakel-col-desc" style="border:1px solid #111; padding:5px 4px; vertical-align:top; word-wrap:break-word;">
                <span t-field="line.name"/>
              </td>
              <td class="nakel-col-qty" style="border:1px solid #111; padding:5px 3px; vertical-align:top; text-align:center;">
                <span t-esc="'%.2f' % (line.product_uom_qty or 0)"/>
                <t t-if="line.product_uom"><span style="font-size:9px;"> <span t-field="line.product_uom.name"/></span></t>
              </td>
              <td class="nakel-col-price" style="border:1px solid #111; padding:5px 2px; vertical-align:top; text-align:right; white-space:nowrap;">
                <span t-esc="'%.2f' % (line.price_unit or 0)"/>
              </td>
              <td t-if="display_discount" class="nakel-col-disc" style="border:1px solid #111; padding:5px 2px; vertical-align:top; text-align:right;">
                <t t-if="line.discount"><span t-esc="'%.0f' % line.discount"/>%</t>
                <t t-else="">—</t>
              </td>
              <td class="nakel-col-tax-body" style="border:1px solid #111; padding:5px 4px; vertical-align:top; text-align:right; word-wrap:break-word;">
                <t t-if="line.tax_id">
                  <t t-set="nakel_line_currency" t-value="doc.currency_id"/>
                  <t t-if="line.currency_id">
                    <t t-set="nakel_line_currency" t-value="line.currency_id"/>
                  </t>
                  <t t-set="tax_comp" t-value="line.tax_id.compute_all(line.price_unit, nakel_line_currency, line.product_uom_qty, product=line.product_id, partner=doc.partner_id, is_refund=0)"/>
                  <t t-foreach="tax_comp.get('taxes') or []" t-as="tax_row">
                    <div><span t-esc="(tax_row.get('name') or '').strip()"/> = <span t-esc="'%.2f' % (tax_row.get('amount') or 0)"/></div>
                  </t>
                </t>
                <t t-else="">—</t>
              </td>
              <td class="nakel-col-sub" style="border:1px solid #111; padding:5px 3px; vertical-align:top; text-align:right; white-space:nowrap;">
                <t t-if="not line.is_downpayment">
                  <span t-esc="'%.2f' % (line.price_subtotal or 0)"/>
                </t>
                <t t-else="">
                  <span style="font-size:10px;">Anticipo</span>
                </t>
              </td>
            </tr>
          </t>
        </tbody>
      </table>

      <div class="row nakel-quote-meta-block" style="margin-top:6px; margin-bottom:10px;">
        <div class="col-5">
          <div style="border:1px solid #ddd; min-height:74px; padding:8px; font-size:10px; line-height:1.45;">
            <div style="font-weight:700; margin-bottom:4px;">Condiciones</div>
            <div>Documento comercial sin valor fiscal.</div>
            <t t-if="doc.validity_date and doc.state in ('draft', 'sent')">
              <div style="margin-top:4px;">Validez de la oferta hasta el <span t-field="doc.validity_date" t-options="{'widget': 'date'}"/>.</div>
            </t>
            <t t-if="doc.currency_id">
              <div style="margin-top:4px;">Moneda: <span t-field="doc.currency_id.name"/>.</div>
            </t>
          </div>
        </div>
        <div class="col-7">
          <table style="width:100%; margin-left:auto; font-size:11px;">
            <tr>
              <td style="text-align:right; padding:2px 4px; font-weight:700;">Subtotal:</td>
              <td style="text-align:right; padding:2px 4px; width:32%;"><span t-esc="'%.2f' % (doc.amount_untaxed or 0)"/></td>
            </tr>
            <t t-if="doc.tax_totals and doc.tax_totals.get('subtotals')">
              <t t-foreach="doc.tax_totals['subtotals']" t-as="subtotal">
                <t t-if="subtotal.get('tax_groups')">
                  <t t-foreach="subtotal['tax_groups']" t-as="tax_group">
                    <tr>
                      <td style="text-align:right; padding:2px 4px; font-weight:700;"><span t-esc="tax_group.get('group_name', '') or 'Impuesto'"/>:</td>
                      <td style="text-align:right; padding:2px 4px;"><span t-esc="'%.2f' % (tax_group.get('tax_amount_currency', 0))"/></td>
                    </tr>
                  </t>
                </t>
              </t>
            </t>
            <t t-elif="doc.amount_tax and doc.amount_tax != 0">
              <tr>
                <td style="text-align:right; padding:2px 4px; font-weight:700;">Impuestos:</td>
                <td style="text-align:right; padding:2px 4px;"><span t-esc="'%.2f' % (doc.amount_tax or 0)"/></td>
              </tr>
            </t>
            <tr>
              <td colspan="2" style="padding-top:2px;">
                <div style="border-top:1px solid #111;"/>
              </td>
            </tr>
            <tr>
              <td style="text-align:right; padding:2px 4px; font-weight:700; font-size:13px;">TOTAL:</td>
              <td style="text-align:right; padding:2px 4px; font-size:13px; font-weight:700;"><span t-esc="'%.2f' % (doc.amount_total or 0)"/></td>
            </tr>
          </table>
        </div>
      </div>

      <t t-if="doc.note">
        <div style="font-size:10px; margin-bottom:10px; padding:8px; border:1px solid #e0e0e0; background:#fafafa;">
          <strong>Notas:</strong><br/>
          <span t-field="doc.note"/>
        </div>
      </t>

      <div style="border-top:1px solid #d0d0d0; padding-top:8px; text-align:center; font-size:10px; line-height:1.4;">
        <div style="font-weight:700;">NAKEL — <span t-out="titulo_documento"/></div>
        <div>Los importes se expresan en la moneda del pedido. Los precios incluyen impuestos según configuración de líneas.</div>
      </div>

      <div style="border-top:1px solid #111; margin-top:14px; padding-top:5px; text-align:center; font-size:10px; color:#3f3f3f;">
        <span style="color:#0095b6;" t-esc="company_website"/>
        <span style="padding:0 8px;">-</span>
        <span>contacto: <span t-esc="company_email"/></span>
        <span style="padding:0 8px;">-</span>
        <span>Tel: <span t-esc="company_phone"/></span>
        <span style="padding:0 8px;">-</span>
        <span>CUIT: <span t-esc="formatted_vat"/></span>
      </div>
    </div>
  </t>
</t>
