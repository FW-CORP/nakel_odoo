<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Dominio dinámico (invoice_user_id = usuario): solo vía código -->
        <record id="action_server_clientes_cc_my_sales" model="ir.actions.server">
            <field name="name">Cuentas corrientes — mis ventas</field>
            <field name="model_id" ref="account.model_account_move"/>
            <!-- Sin groups_id: la visibilidad la marca el menú; si no, un admin sin
                 group_cc_my_sales recibía acceso denegado al ejecutar la acción. -->
            <field name="state">code</field>
            <field name="code">action = env['account.move'].action_clientes_cc_open_my_sales_pivot()</field>
        </record>

        <!--
        NO colgar de sale.menu_sale_report: en Odoo 18 ese menú es solo
        sales_team.group_sale_manager, los vendedores (group_sale_salesman) no lo ven.
        sale.sale_order_menu = Órdenes: cotizaciones, pedidos, clientes — visible para vendedor.
        -->
        <menuitem
            id="menu_clientes_cc_my_sales"
            name="Cuentas corrientes (mis ventas)"
            parent="sale.sale_order_menu"
            action="action_server_clientes_cc_my_sales"
            sequence="45"
            groups="base.group_system,sales_team.group_sale_salesman,sales_team.group_sale_manager,clientes_cc_detalle.group_cc_my_sales"
        />
    </data>
</odoo>
