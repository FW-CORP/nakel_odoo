<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        account_followup (EE): campos total_due / total_all_due no entran en web_read
        si el usuario no tiene grupos contables. Una vista Nakel suele sumar preventistas
        al botón open_customer_statement (prioridad ~99); al ver el botón, el OWL
        parsea <field name="total_all_due"/> y revienta.

        Prioridad 150: aplica después de esa herencia y deja el botón *solo* para
        usuarios que sí reciben esos campos. Los preventistas usan la CC Nakel.
    -->
    <record id="view_partner_form_followup_statement_safe" model="ir.ui.view">
        <field name="name">res.partner.form: Customer Statement solo contabilidad</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="account_followup.res_partner_view_form"/>
        <field name="priority">150</field>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='open_customer_statement']" position="attributes">
                <attribute name="groups">account.group_account_basic,account.group_account_readonly,account.group_account_invoice</attribute>
                <attribute name="invisible">not has_moves or total_all_due == 0</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_partner_tree_customer_statements_total_due_groups" model="ir.ui.view">
        <field name="name">res.partner list customer statements: total_due solo contabilidad</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="account_followup.customer_statements_tree_view"/>
        <field name="priority">40</field>
        <field name="arch" type="xml">
            <field name="total_due" position="attributes">
                <attribute name="groups">account.group_account_basic,account.group_account_readonly,account.group_account_invoice</attribute>
            </field>
        </field>
    </record>
</odoo>
