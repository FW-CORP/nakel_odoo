<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Lectura explícita en XML (evita depender solo del CSV en deploy).
             Dos grupos: Nakel CC + vendedor estándar (muchos preventistas solo tienen el segundo). -->
        <!-- perm_write: la UI (actividades, seguidores, algunos computed) puede llamar write()
             en asientos; con perm_write=0 Odoo muestra "no puede modificar" aunque el ACL
             tenga lectura. Las reglas + account.move.write siguen bloqueando líneas/datos
             sensibles en facturas publicadas. Crear/borrar asientos sigue prohibido. -->
        <record id="access_clientes_cc_account_move_read" model="ir.model.access">
            <field name="name">clientes_cc account.move read (Nakel CC)</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="group_id" ref="clientes_cc_detalle.group_cc_my_sales"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>
        <record id="access_clientes_cc_account_move_read_salesman" model="ir.model.access">
            <field name="name">clientes_cc account.move read (vendedor)</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="group_id" ref="sales_team.group_sale_salesman"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>
        <record id="access_clientes_cc_account_move_line_read" model="ir.model.access">
            <field name="name">clientes_cc account.move.line read (Nakel CC)</field>
            <field name="model_id" ref="account.model_account_move_line"/>
            <field name="group_id" ref="clientes_cc_detalle.group_cc_my_sales"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>
        <record id="access_clientes_cc_account_move_line_read_salesman" model="ir.model.access">
            <field name="name">clientes_cc account.move.line read (vendedor)</field>
            <field name="model_id" ref="account.model_account_move_line"/>
            <field name="group_id" ref="sales_team.group_sale_salesman"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>
    </data>
</odoo>
