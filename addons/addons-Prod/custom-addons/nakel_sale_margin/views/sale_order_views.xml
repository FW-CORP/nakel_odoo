<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Objetivo de negocio: ocultar margen y % al pie de la OV a todos los
        vendedores; solo lo ven quienes pertenezcan al grupo «Ver Margen de Ventas»
        (p. ej. gerentes). sale_margin deja el contenedor con groups=base.group_user,
        por eso además se fuerza el mismo grupo NAKEL en ese div y en los campos
        internos. El xpath del span evita un "(" huérfano si el campo % queda oculto.
    -->
    <record id="sale_order_margin_groups" model="ir.ui.view">
        <field name="name">sale.order.margin.groups</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_margin.sale_margin_sale_order"/>
        <field name="arch" type="xml">
            <!-- Pie completo: usuario interno Y miembro del grupo NAKEL -->
            <xpath expr="//field[@name='tax_totals']/following-sibling::*[1]" position="attributes">
                <attribute name="groups">base.group_user,nakel_sale_margin.group_ver_margen</attribute>
            </xpath>
            <xpath expr="//field[@name='margin']" position="attributes">
                <attribute name="groups">nakel_sale_margin.group_ver_margen</attribute>
            </xpath>
            <xpath expr="//field[@name='margin_percent']" position="attributes">
                <attribute name="groups">nakel_sale_margin.group_ver_margen</attribute>
            </xpath>
            <xpath expr="//span[.//field[@name='margin_percent']]" position="attributes">
                <attribute name="groups">nakel_sale_margin.group_ver_margen</attribute>
            </xpath>
        </field>
    </record>

    <!--
        Mismas reglas en líneas: columnas Margen / % solo con grupo «Ver Margen de Ventas».
    -->
    <record id="sale_order_line_margin_groups" model="ir.ui.view">
        <field name="name">sale.order.line.margin.groups</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_margin.sale_margin_sale_order_line_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list/field[@name='margin']" position="attributes">
                <attribute name="groups">nakel_sale_margin.group_ver_margen</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/list/field[@name='margin_percent']" position="attributes">
                <attribute name="groups">nakel_sale_margin.group_ver_margen</attribute>
            </xpath>
        </field>
    </record>
</odoo>
