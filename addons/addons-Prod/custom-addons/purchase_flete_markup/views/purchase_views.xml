<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_order_form_inherit_flete_percent" model="ir.ui.view">
        <field name="name">purchase.order.form.flete.percent.v3</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='currency_id']" position="after">
                <group string="Flete">
                    <field name="x_flete_percent"/>
                    <button name="action_apply_freight_markup"
                            type="object"
                            string="Aplicar recargo"
                            class="btn-primary"
                            invisible="state in ['purchase','done','cancel']"/>
                    <button name="action_reset_freight_markup"
                            type="object"
                            string="Revertir recargo"
                            invisible="state in ['purchase','done','cancel']"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
