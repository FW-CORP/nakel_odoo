analyze_*.py
check_*.py
verify_*.py
diagnose_*.py
smoke_*.py
test_dump.py
test_strategies.py

# ─── Datos de proveedores y muestras (no compartir) ───────────────
# PDFs/Excels reales de listas de proveedores
data/
samples/
*.pdf
*.xls
*.xlsx
*.csv
!**/requirements.txt
# Permitir el archivo de seguridad del módulo (Odoo lo necesita en el repo)
!odoo_module/nakel_supplier_pricelist/security/ir.model.access.csv
# Permitir docs/diagrams.pdf si hubiera en el futuro
!docs/**/*.pdf

